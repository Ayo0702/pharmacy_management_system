<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pharmacy_prescription_list" model="ir.ui.view">
        <field name="name">pharmacy.prescription.list</field>
        <field name="model">pharmacy.prescription</field>
                <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="hospital_id"/>
                <field name="pharmacy_id"/>
                <field name="date_prescribed"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_prescription_form" model="ir.ui.view">
        <field name="name">pharmacy.prescription.form</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <form string="Prescription">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_create_picking" type="object" string="Create Picking" class="btn-secondary" invisible="state != 'approved' or picking_id"/>
                    <button name="action_dispense" type="object" string="Dispense" class="btn-primary" invisible="state not in ['approved', 'partial']"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state in ['cancel', 'dispensed']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_picking" icon="fa-truck" invisible="not picking_id">
                            <field name="picking_id" widget="statinfo" string="Delivery"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_claims" icon="fa-file-text-o">
                            <field name="claim_count" widget="statinfo" string="Claims"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_controlled_logs" icon="fa-shield">
                            <field name="controlled_log_count" widget="statinfo" string="Controlled Logs"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_invoice" icon="fa-money" invisible="not invoice_id">
                            <field name="invoice_id" widget="statinfo" string="Invoice"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="hospital_id"/>
                            <field name="pharmacy_id"/>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                            <field name="date_prescribed"/>
                        </group>
                        <group>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </group>
                    <group invisible="1">
                        <field name="picking_id"/>
                        <field name="invoice_id"/>
                        <field name="claim_count"/>
                        <field name="controlled_log_count"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="drug_id"/>
                                    <field name="dosage"/>
                                    <field name="qty_prescribed"/>
                                    <field name="uom_id"/>
                                    <field name="qty_dispensed"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_pharmacy_prescription_kanban" model="ir.ui.view">
        <field name="name">pharmacy.prescription.kanban</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <kanban class="pharma-kanban o_kanban_small_column pharmacy-prescription-kanban" 
                    default_group_by="state" 
                    record_drop="false">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="hospital_id"/>
                <field name="pharmacy_id"/>
                <field name="date_prescribed"/>
                <field name="state"/>
                <field name="attachment_ids"/>
                <field name="claim_count"/>
                <field name="controlled_log_count"/>
                <field name="picking_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click pharmacy-prescription-card pharma-card">
                            <!-- Header with icon, title, status and toggle -->
                            <div class="o_kanban_record_top">
                                <div class="kanban-header-left">
                                    <div class="kanban-icon-wrapper">
                                        <i class="fa fa-file-text-o kanban-icon" title="Prescription"></i>
                                    </div>
                                    <div class="o_kanban_record_headings">
                                        <div class="o_kanban_record_title">
                                            <strong><field name="name"/></strong>
                                            <div class="o_kanban_record_subtitle">
                                                <span class="status-dot" 
                                                      t-attf-class="status-dot status-#{record.state.raw_value}"></span>
                                                <field name="state" 
                                                       decoration-success="state == 'dispensed'" 
                                                       decoration-info="state == 'approved'" 
                                                       decoration-muted="state == 'draft'"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Content Section -->
                            <div class="oe_kanban_content">
                                <!-- Patient and Doctor Info -->
                                <div class="o_kanban_record_body">
                                    <div class="config-tag">
                                        <i class="fa fa-user" title="Patient"></i>
                                        <field name="patient_id"/>
                                    </div>
                                    <div class="config-tag">
                                        <i class="fa fa-user-md" title="Doctor"></i>
                                        <field name="doctor_id"/>
                                    </div>
                                </div>
                                
                                <!-- Configuration Tags -->
                                <div class="o_kanban_record_bottom config-tags">
                                    <div class="oe_kanban_bottom_left">
                                        <!-- Hospital -->
                                        <div class="config-tag">
                                            <i class="fa fa-hospital-o" title="Hospital"></i>
                                            <field name="hospital_id"/>
                                        </div>
                                        
                                        <!-- Pharmacy -->
                                        <div class="config-tag">
                                            <i class="fa fa-home" title="Pharmacy"></i>
                                            <field name="pharmacy_id"/>
                                        </div>
                                        
                                        <!-- Date -->
                                        <div class="config-tag">
                                            <i class="fa fa-calendar" title="Date Prescribed"></i>
                                            <field name="date_prescribed"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Statistics in Two Columns -->
                                <div class="o_kanban_record_bottom stats-section">
                                    <div class="stats-column stats-left">
                                        <!-- Claims -->
                                        <div class="stat-item">
                                            <i class="fa fa-file-text text-primary"></i>
                                            <span class="stat-value">
                                                <field name="claim_count"/> Claims
                                            </span>
                                        </div>
                                        
                                        <!-- Controlled Logs -->
                                        <div class="stat-item">
                                            <i class="fa fa-shield text-info"></i>
                                            <span class="stat-value">
                                                <field name="controlled_log_count"/> Logs
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <div class="stats-column stats-right">
                                        <!-- Attachments -->
                                        <div class="stat-item" t-if="record.attachment_ids and record.attachment_ids.raw_value and record.attachment_ids.raw_value.length">
                                            <i class="fa fa-paperclip text-info"></i>
                                            <span class="stat-value">
                                                <t t-esc="record.attachment_ids.raw_value.length"/> Files
                                            </span>
                                        </div>
                                        
                                        <!-- Picking -->
                                        <div class="stat-item" t-if="record.picking_id.raw_value">
                                            <i class="fa fa-truck text-success"></i>
                                            <span class="stat-value">Delivery</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Quick Actions -->
                                <div class="o_kanban_record_bottom actions-section">
                                    <div class="oe_kanban_bottom_right">
                                        <button name="action_approve" type="object" 
                                                class="btn-icon btn-preview" 
                                                invisible="state != 'draft'"
                                                title="Approve Prescription">
                                            <i class="fa fa-check"></i>
                                        </button>
                                        <button name="action_dispense" type="object" 
                                                class="btn-icon btn-publish" 
                                                invisible="state not in ['approved', 'partial']"
                                                title="Dispense Prescription">
                                            <i class="fa fa-truck"></i>
                                        </button>
                                        <button name="action_cancel" type="object" 
                                                class="btn-icon btn-duplicate"
                                                invisible="state in ['cancel', 'dispensed']"
                                                title="Cancel Prescription">
                                            <i class="fa fa-times"></i>
                                        </button>
                                        <button name="action_view_picking" type="object" 
                                                class="btn-icon btn-refresh"
                                                invisible="not picking_id"
                                                title="View Delivery">
                                            <i class="fa fa-external-link"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_prescription_volume_pivot" model="ir.ui.view">
        <field name="name">prescription.volume.pivot</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <pivot string="Prescription Volume Analysis">
                <field name="hospital_id" type="row"/>
                <field name="state" type="row"/>
                <field name="date_prescribed" type="col" interval="month"/>
                <field name="count_field" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_pharmacy_prescription" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">pharmacy.prescription</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
    </record>
    <record id="search_pharmacy_prescription" model="ir.ui.view">
        <field name="name">pharmacy.prescription.search</field>
        <field name="model">pharmacy.prescription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="hospital_id"/>
                <field name="pharmacy_id"/>
                <field name="drug_ids" string="Drug"/>
                <field name="date_prescribed" filter_domain="[('date_prescribed', operator, value)]"/>
                <separator/>
                <filter string="Today's Prescriptions" name="today_prescriptions" domain="[('date_prescribed','=', context_today())]"/>
                <separator/>
                <filter string="Draft" name="state_draft" domain="[('state','=','draft')]"/>
                <filter string="Approved" name="state_approved" domain="[('state','=','approved')]"/>
                <filter string="Dispensed" name="state_dispensed" domain="[('state','=','dispensed')]"/>
                <filter string="Canceled" name="state_cancel" domain="[('state','=','cancel')]"/>
                <group expand="0" string="Group By">
                    <filter string="Hospital" name="grp_hospital" context="{'group_by':'hospital_id'}"/>
                    <filter string="Pharmacy" name="grp_pharmacy" context="{'group_by':'pharmacy_id'}"/>
                    <filter string="Patient" name="grp_patient" context="{'group_by':'patient_id'}"/>
                    <filter string="Doctor" name="grp_doctor" context="{'group_by':'doctor_id'}"/>
                    <filter string="State" name="grp_state" context="{'group_by':'state'}"/>
                    <filter string="Date" name="grp_date" context="{'group_by':'date_prescribed'}"/>
                    <filter string="Month" name="grp_month" context="{'group_by':'date_prescribed:month'}"/>
                    <filter string="Week" name="grp_week" context="{'group_by':'date_prescribed:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <menuitem id="menu_pharmacy_prescription" parent="pharmacy_management_system.menu_pharmacy_prescriptions" action="action_pharmacy_prescription"/>

    <record id="view_pharmacy_return_quarantine_list" model="ir.ui.view">
        <field name="name">pharmacy.return.quarantine.list</field>
        <field name="model">pharmacy.return.quarantine</field>
                <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="drug_id"/>
                <field name="qty"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_pharmacy_return_quarantine_form" model="ir.ui.view">
        <field name="name">pharmacy.return.quarantine.form</field>
        <field name="model">pharmacy.return.quarantine</field>
        <field name="arch" type="xml">
            <form string="Return Quarantine">
                <header>
                    <button name="action_dispose" type="object" string="Mark as Disposed" class="btn-primary" invisible="state != 'awaiting'"/>
                    <button name="action_view_refund" type="object" string="Create / View Refund" class="btn-secondary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="drug_id"/>
                        <field name="hospital_id"/>
                        <field name="pharmacy_id"/>
                        <field name="qty"/>
                        <field name="reason"/>
                        <field name="invoice_id"/>
                        <field name="refund_id" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_pharmacy_return_quarantine" model="ir.actions.act_window">
        <field name="name">Return / Quarantine</field>
        <field name="res_model">pharmacy.return.quarantine</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="search_pharmacy_return_quarantine" model="ir.ui.view">
        <field name="name">pharmacy.return.quarantine.search</field>
        <field name="model">pharmacy.return.quarantine</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="drug_id"/>
                <filter string="Awaiting" name="state_awaiting" domain="[('state','=','awaiting')]"/>
                <filter string="Disposed" name="state_disposed" domain="[('state','=','disposed')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="grp_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <menuitem id="menu_pharmacy_return_quarantine" parent="pharmacy_management_system.menu_pharmacy_operations" action="action_pharmacy_return_quarantine"/>

</odoo>


