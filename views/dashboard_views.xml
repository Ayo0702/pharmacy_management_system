<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         Pharmacy Management Dashboard
    ═══════════════════════════════════════════════════ -->

    <!-- Prescription Volume Graph -->
    <record id="action_dashboard_prescriptions" model="ir.actions.act_window">
        <field name="name">Prescription Volume</field>
        <field name="res_model">pharmacy.prescription</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="view_id" ref="pharmacy_management_system.view_prescription_volume_graph"/>
    </record>

    <!-- Insurance Claims Graph -->
    <record id="action_dashboard_insurance" model="ir.actions.act_window">
        <field name="name">Insurance Claims</field>
        <field name="res_model">pharmacy.insurance.claim</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="view_id" ref="pharmacy_management_system.view_insurance_claims_graph"/>
    </record>

    <!-- Controlled Substance Graph -->
    <record id="action_dashboard_controlled" model="ir.actions.act_window">
        <field name="name">Controlled Substances</field>
        <field name="res_model">pharmacy.controlled.log</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="view_id" ref="pharmacy_management_system.view_controlled_activity_graph"/>
    </record>

    <!-- Drug Coverage Graph -->
    <record id="action_dashboard_drug_coverage" model="ir.actions.act_window">
        <field name="name">Drug Coverage</field>
        <field name="res_model">pharmacy.drug.coverage</field>
        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="pharmacy_management_system.view_drug_coverage_graph"/>
    </record>

    <!-- Expiring Lots -->
    <record id="action_dashboard_expiring" model="ir.actions.act_window">
        <field name="name">Expiring Lots</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('expiration_date','!=',False)]</field>
        <field name="view_id" ref="pharmacy_management_system.view_expiring_lots_list"/>
    </record>

    <!-- Shortage Alerts -->
    <record id="action_dashboard_shortages" model="ir.actions.act_window">
        <field name="name">Shortage Alerts</field>
        <field name="res_model">pharmacy.drug.coverage</field>
        <field name="view_mode">list</field>
        <field name="domain">[('shortage_flag','=',True)]</field>
        <field name="view_id" ref="pharmacy_management_system.view_shortage_alerts_list"/>
    </record>

    <!-- ── Dashboard Client Action ── -->
    <record id="action_open_pharmacy_dashboard" model="ir.actions.client">
        <field name="name">Pharmacy Dashboard</field>
        <field name="tag">pharmacy_management_system.Dashboard</field>
    </record>

</odoo>