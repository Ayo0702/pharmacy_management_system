<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pharmacy_alert_rule_list" model="ir.ui.view">
        <field name="name">pharmacy.alert.rule.list</field>
        <field name="model">pharmacy.alert.rule</field>
                <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="rule_type"/>
                <field name="threshold"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_pharmacy_alert_rule_form" model="ir.ui.view">
        <field name="name">pharmacy.alert.rule.form</field>
        <field name="model">pharmacy.alert.rule</field>
        <field name="arch" type="xml">
            <form string="Alert Rule">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="rule_type"/>
                            <field name="threshold"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="message_template" placeholder="Template for alert messages..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Alert Rule Kanban View -->
    <record id="view_pharmacy_alert_rule_kanban" model="ir.ui.view">
        <field name="name">pharmacy.alert.rule.kanban</field>
        <field name="model">pharmacy.alert.rule</field>
        <field name="arch" type="xml">
            <kanban class="pharma-kanban o_kanban_small_column pharmacy-alert-rule-kanban" default_group_by="rule_type">
                <field name="name"/>
                <field name="rule_type"/>
                <field name="threshold"/>
                <field name="active"/>
                <field name="message_template"/>
                <field name="company_id"/>
                <field name="hospital_id"/>
                <field name="pharmacy_id"/>
                <field name="drug_category_id"/>
                <field name="drug_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click pharmacy-alert-rule-card pharma-card">
                            <!-- Header with icon, title, status -->
                            <div class="o_kanban_record_top">
                                <div class="kanban-header-left">
                                    <div class="kanban-icon-wrapper">
                                        <i class="fa fa-bell kanban-icon" title="Alert Rule"></i>
                                    </div>
                                    <div class="o_kanban_record_headings">
                                        <div class="o_kanban_record_title">
                                            <strong><field name="name"/></strong>
                                            <div class="o_kanban_record_subtitle">
                                                <span class="status-dot" 
                                                      t-attf-class="status-dot status-#{record.rule_type.raw_value}"></span>
                                                <field name="rule_type" 
                                                       decoration-success="rule_type == 'expiry'" 
                                                       decoration-info="rule_type == 'stock'" 
                                                       decoration-warning="rule_type == 'recall'"
                                                       decoration-danger="rule_type == 'controlled'"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Content Section -->
                            <div class="oe_kanban_content">
                                <!-- Threshold -->
                                <div class="o_kanban_record_body" t-if="record.threshold.raw_value">
                                    <div class="config-tag">
                                        <i class="fa fa-sliders" title="Threshold"></i>
                                        <span><t t-esc="record.threshold.raw_value"/></span>
                                    </div>
                                </div>
                                
                                <!-- Configuration Tags -->
                                <div class="o_kanban_record_bottom config-tags">
                                    <div class="oe_kanban_bottom_left">
                                        <!-- Company -->
                                        <div class="config-tag" t-if="record.company_id.raw_value">
                                            <i class="fa fa-building" title="Company"></i>
                                            <field name="company_id"/>
                                        </div>
                                        
                                        <!-- Hospital -->
                                        <div class="config-tag" t-if="record.hospital_id.raw_value">
                                            <i class="fa fa-hospital-o" title="Hospital"></i>
                                            <field name="hospital_id"/>
                                        </div>
                                        
                                        <!-- Pharmacy -->
                                        <div class="config-tag" t-if="record.pharmacy_id.raw_value">
                                            <i class="fa fa-home" title="Pharmacy"></i>
                                            <field name="pharmacy_id"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Additional Info -->
                                <div class="o_kanban_record_bottom config-tags" t-if="record.drug_category_id.raw_value or record.drug_id.raw_value">
                                    <div class="oe_kanban_bottom_left">
                                        <!-- Drug Category -->
                                        <div class="config-tag" t-if="record.drug_category_id.raw_value">
                                            <i class="fa fa-tags" title="Drug Category"></i>
                                            <field name="drug_category_id"/>
                                        </div>
                                        
                                        <!-- Drug -->
                                        <div class="config-tag" t-if="record.drug_id.raw_value">
                                            <i class="fa fa-medkit" title="Drug"></i>
                                            <field name="drug_id"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Status Badge -->
                                <div class="o_kanban_record_bottom stats-section">
                                    <div class="stats-column stats-left">
                                        <div class="stat-item">
                                            <span t-if="record.active.raw_value" class="badge badge-success">Active</span>
                                            <span t-if="!record.active.raw_value" class="badge badge-secondary">Inactive</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_pharmacy_alert_rule" model="ir.actions.act_window">
        <field name="name">Alert Rules</field>
        <field name="res_model">pharmacy.alert.rule</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="search_pharmacy_alert_rule" model="ir.ui.view">
        <field name="name">pharmacy.alert.rule.search</field>
        <field name="model">pharmacy.alert.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="rule_type"/>
                <filter string="Active" name="active_true" domain="[('active','=',True)]"/>
                <filter string="Archived" name="active_false" domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="grp_type" context="{'group_by':'rule_type'}"/>
                    <filter string="Active" name="grp_active" context="{'group_by':'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <menuitem id="menu_pharmacy_alert_rule" parent="pharmacy_management_system.menu_pharmacy_alerts" action="action_pharmacy_alert_rule"/>

</odoo>


