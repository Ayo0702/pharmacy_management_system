<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="pharmacy_management_system.DashboardTemplate">
    <div class="o_pharma_dashboard o_view_controller">

        <!-- KPI Row -->
        <div class="o_pharma_kpi_row">

            <div class="o_pharma_kpi_card" t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_prescriptions')">
                <div class="o_pharma_kpi_icon" style="background:#d1e9ff;color:#1677ff;">
                    <i class="fa fa-file-text-o"/>
                </div>
                <div class="o_pharma_kpi_body">
                    <div class="o_pharma_kpi_value"><t t-esc="state.prescriptionCount"/></div>
                    <div class="o_pharma_kpi_label">Total Prescriptions</div>
                </div>
            </div>

            <div class="o_pharma_kpi_card o_pharma_kpi_danger" t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_shortages')">
                <div class="o_pharma_kpi_icon" style="background:#ffe0e0;color:#d32f2f;">
                    <i class="fa fa-exclamation-triangle"/>
                </div>
                <div class="o_pharma_kpi_body">
                    <div class="o_pharma_kpi_value"><t t-esc="state.shortageCount"/></div>
                    <div class="o_pharma_kpi_label">Drug Shortages</div>
                </div>
            </div>

            <div class="o_pharma_kpi_card" t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_insurance')">
                <div class="o_pharma_kpi_icon" style="background:#e8f5e9;color:#388e3c;">
                    <i class="fa fa-shield"/>
                </div>
                <div class="o_pharma_kpi_body">
                    <div class="o_pharma_kpi_value"><t t-esc="state.claimsCount"/></div>
                    <div class="o_pharma_kpi_label">Insurance Claims</div>
                </div>
            </div>

            <div class="o_pharma_kpi_card o_pharma_kpi_warning" t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_expiring')">
                <div class="o_pharma_kpi_icon" style="background:#fff8e1;color:#f9a825;">
                    <i class="fa fa-clock-o"/>
                </div>
                <div class="o_pharma_kpi_body">
                    <div class="o_pharma_kpi_value"><t t-esc="state.expiringCount"/></div>
                    <div class="o_pharma_kpi_label">Expiring Lots</div>
                </div>
            </div>

        </div>

        <!-- Quick Links Row -->
        <div class="o_pharma_quicklinks">
            <h5 class="o_pharma_section_title">Quick Reports</h5>
            <div class="o_pharma_link_grid">

                <button class="btn btn-outline-primary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_prescriptions')">
                    <i class="fa fa-bar-chart me-2"/>Prescription Volume
                </button>

                <button class="btn btn-outline-primary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_insurance')">
                    <i class="fa fa-bar-chart me-2"/>Insurance Claims
                </button>

                <button class="btn btn-outline-primary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_controlled')">
                    <i class="fa fa-bar-chart me-2"/>Controlled Substances
                </button>

                <button class="btn btn-outline-primary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_drug_coverage')">
                    <i class="fa fa-bar-chart me-2"/>Drug Coverage
                </button>

                <button class="btn btn-outline-secondary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_shortages')">
                    <i class="fa fa-exclamation-triangle me-2"/>Shortage Alerts
                </button>

                <button class="btn btn-outline-secondary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_dashboard_expiring')">
                    <i class="fa fa-clock-o me-2"/>Expiring Lots
                </button>

                <button class="btn btn-outline-secondary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_prescription_rx_kpis')">
                    <i class="fa fa-table me-2"/>RX KPIs (Pivot)
                </button>

                <button class="btn btn-outline-secondary o_pharma_link_btn"
                    t-on-click="() => this.openAction('pharmacy_management_system.action_treatment_report')">
                    <i class="fa fa-heartbeat me-2"/>Treatment Report
                </button>

            </div>
        </div>

    </div>
</t>
</templates>